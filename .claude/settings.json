{
  "permissions": {
    "allow": [
      "Bash(gh api *)",
      "Bash(sqlite3 *)",
      "Bash(git commit *)",
      "Bash(cargo fmt)",
      "Bash(cargo fmt --all -- --check)",
      "Bash(cargo check *)",
      "Bash(cargo clippy *)",
      "Bash(cargo test *)",
      "Bash(cargo audit)",
      "Bash(cargo deny *)",
      "Bash(cargo tree *)",
      "Bash(just check)",
      "Bash(just fmt)",
      "Bash(just lint)",
      "Bash(just test)",
      "Bash(just audit)",
      "Bash(just deny)",
      "Bash(just baseline)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath // \"\"' | { read -r f; case \"$f\" in *.rs) cargo check --all-targets --all-features --message-format=short;; esac; }",
            "timeout": 60,
            "statusMessage": "cargo check"
          }
        ]
      }
    ]
  }
}
