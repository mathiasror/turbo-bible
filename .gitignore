# Rust
# Generated by Cargo
# will have compiled files and executables
debug
target

# Data pipeline output (built per-translation .db.zst files and manifest).
dist/

# Conventional out-of-tree path for a local scrollmapper checkout the
# data-pipeline subcommands read from.
data/scrollmapper-checkout/

# Regenerable output of `turbo-bible-data audit-licenses`. The curated
# manifest in `data/manifest_source.toml` is the source of truth.
data/licenses.csv

# Pipeline output bundled into the TUI binary at build time. Populate
# with `just bundle-translations`. Each .db.zst is ~4–6 MB; total ~52 MB.
crates/turbo-bible-tui/assets/*.db.zst

# VHS intermediate trace GIFs (the real output is the PNG each tape writes)
demo/_screenshots-trace.gif
demo/_og-trace.gif

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# Output of the /rust-review skill — point-in-time artifact, regenerated
# each run. Baseline logs already live under target/rust-review/.
rust-review.md

# Per-user Claude Code settings — keep team-shared rules in
# .claude/settings.json (tracked) instead.
.claude/settings.local.json

# Claude Code scheduler runtime lock — per-session, never shared.
.claude/scheduled_tasks.lock

# rustc will dump stack traces when hitting an internal compiler error to PWD
rustc-ice-*.txt

